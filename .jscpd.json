{
  "threshold": 5,
  "minLines": 30,
  "minTokens": 180,
  "reporters": ["console"],
  "formats": ["javascript", "css", "html"],
  "ignore": [
    "node_modules/**",
    "js/vendor/**",
    "admin/js/vendor/**",
    "assets/**",
    "downloads/**",
    "plugins/**/references/claude-original/**",
    ".claude/**",
    "playwright-report/**",
    "test-results/**",
    ".lighthouseci/**"
  ]
}
