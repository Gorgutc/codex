---
/**
 * FreeAssetsSidebar — sidebar shipped on /free-assets/.  Reuses the
 * same chrome (logo, contact, theme-toggle, cards-toggle, footer
 * pills) as the portfolio Sidebar.  Header carries the legacy filter
 * stack from codex/free-assets.html:141-269:
 *
 *   - tags-dropdown (OR-filter over the 6 FA categories — hides the
 *     non-selected .tag-card entries in the cards list)
 *   - tags-divider
 *   - sidebar__row containing the game-switch (FA semantics: filters
 *     fa-cards in the active category by `data-game-asset`, NOT the
 *     categories themselves — v0.8.9 [L5]) and the cards-count
 *     ("6 categories" → "8 assets" once a category is opened)
 *
 * `activeTag` is the SSR-pre-selected category — JS will rebind it
 * from location.hash on mount via src/scripts/free-assets.ts.
 */
import ThemeToggle from '@components/ui/ThemeToggle.astro';
import TagCard from '@components/work/TagCard.astro';
import {
  FA_CATEGORY_ORDER,
  FA_DATA,
  type FaCategoryKey,
} from '@data/free-assets';

export interface Props {
  activeTag: FaCategoryKey;
}

const { activeTag } = Astro.props;

// Visual + meta payload per tag-card. Order + labels + thumb-id
// mirror codex/free-assets.html:276-385 (the legacy renderGrid
// chose a representative thumbnail per category).
const TAG_CARDS: Array<{
  tag: FaCategoryKey;
  title: string;
  cat: string;
  format: string;
  desc: string;
  thumbId: string;
  thumbLabel: string;
  game?: boolean;
}> = [
  { tag: 'hard-surface', title: 'Hard Surface',          cat: 'Hard Surface', format: '.blend .fbx',         desc: 'Props, weapons, armour. AAA-ready topology.',     thumbId: 'orbital-mk-ii', thumbLabel: 'Hard Surface' },
  { tag: 'product',      title: 'Product Visualization', cat: 'Product Viz',  format: '.blend',              desc: 'Studio scenes, lighting rigs, camera setups.',    thumbId: 'corten-series', thumbLabel: 'Product Viz'  },
  { tag: 'game',         title: 'Game-Ready',            cat: 'Game Assets',  format: '.fbx LOD 0–2',        desc: 'Optimised props with LODs and 4K PBR maps.',      thumbId: 'nightshard',    thumbLabel: 'Game Assets', game: true },
  { tag: 'organic',      title: 'Organic',               cat: 'Organic',      format: '.blend rig',          desc: 'Sculpted creatures, fur grooms, rigs.',           thumbId: 'nyx-panther',   thumbLabel: 'Organic'      },
  { tag: 'animation',    title: 'Animation',             cat: 'Animation',    format: '.blend .mp4',         desc: 'Turntables, reveal loops, camera paths.',         thumbId: 'helix-reveal',  thumbLabel: 'Animation'    },
  { tag: 'cad',          title: 'CAD',                   cat: 'CAD',          format: '.blend .step .stl',   desc: 'Parametric assemblies, print-ready geometry.',    thumbId: 'mech-link',     thumbLabel: 'CAD'          },
];

const totalCategories = FA_CATEGORY_ORDER.length;

// Dropdown options — "All" toggle + 6 categories. Counts are derived
// from FA_DATA so they stay in sync with the catalogue.
const DROPDOWN_OPTIONS: Array<{ value: FaCategoryKey | 'all'; label: string; count: number }> = [
  { value: 'all', label: 'All', count: totalCategories },
  ...TAG_CARDS.map((t) => ({
    value: t.tag,
    label: t.title === 'Game-Ready' ? 'Game Assets' : t.cat,
    count: FA_DATA[t.tag].length,
  })),
];
---

<aside class="sidebar" aria-label="Asset categories" transition:persist="fa-sidebar">
  <header class="site-header" role="banner">
    <div class="header-top">
      <a
        href="/"
        class="logo"
        id="logo-back-portfolio"
        aria-label="Codex — back to portfolio"
        data-cursor="link"
      >
        <span class="logo__text">CODEX</span>
      </a>

      <div class="header-top__controls">
        <a
          href="https://t.me/WhiteCatWeb"
          class="contact-btn"
          id="contact-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Contact via Telegram"
          title="Contact · Telegram"
          data-cursor="link"
        >
          <svg
            class="contact-btn__icon"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M2.5 10.5l15-7-2.7 14-5-4.3-2.7 3V12l7-6.3" />
          </svg>
          <span class="contact-btn__label">Contact</span>
        </a>

        <ThemeToggle />

        <button
          type="button"
          class="cards-toggle"
          id="cards-toggle"
          aria-expanded="true"
          aria-controls="cards-scroll"
          aria-label="Hide categories panel"
          data-cursor="link"
        >
          <span class="cards-toggle__icon cards-toggle__icon--open" aria-hidden="true">‹‹</span>
          <span class="cards-toggle__icon cards-toggle__icon--closed" aria-hidden="true">››</span>
          <span class="cards-toggle__label">Hide categories</span>
        </button>
      </div>
    </div>

    {/* TAGS DROPDOWN — filters which tag-cards stay visible in the list. */}
    <div class="tags-dropdown" id="tags-dropdown" data-open="false">
      <button
        type="button"
        class="tags-dropdown__trigger"
        id="tags-dropdown-trigger"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-controls="tags-dropdown-panel"
        aria-label="Filter by category"
        data-cursor="link"
      >
        <span class="tags-dropdown__chips" id="tags-dropdown-chips" aria-hidden="true"></span>
        <span class="tags-dropdown__placeholder" id="tags-dropdown-placeholder">Filter by category</span>
        <svg
          class="tags-dropdown__chevron"
          viewBox="0 0 16 16"
          width="14"
          height="14"
          aria-hidden="true"
          focusable="false"
        >
          <path
            d="M3 6 L8 11 L13 6"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
      </button>
      <div class="tags-dropdown__overlay" id="tags-dropdown-overlay" aria-hidden="true"></div>
      <div
        class="tags-dropdown__panel"
        id="tags-dropdown-panel"
        role="listbox"
        aria-multiselectable="true"
        aria-label="Categories"
        hidden
      >
        {DROPDOWN_OPTIONS.map(({ value, label, count }) => (
          <label class="tags-dropdown__option" role="option">
            <input
              type="checkbox"
              class="tags-dropdown__checkbox"
              data-filter={value}
              aria-label={label}
            />
            <span class="tags-dropdown__label">{label}</span>
            <span class="tags-dropdown__option-count">{count}</span>
          </label>
        ))}
      </div>
    </div>

    <div class="tags-divider" aria-hidden="true"></div>
    <div class="sidebar__row">
      <label
        class="game-switch"
        id="game-switch-label"
        title="Filter the current category to game-ready assets only (does not switch category)"
        data-cursor="link"
      >
        <input
          type="checkbox"
          id="game-switch"
          class="game-switch__input"
          role="switch"
          aria-checked="false"
          aria-describedby="game-switch-hint"
        />
        <span class="game-switch__track" aria-hidden="true"><span class="game-switch__thumb"></span></span>
        <span class="game-switch__label">Game assets only</span>
        <span id="game-switch-hint" class="sr-only">Filters the current category to game-ready assets only</span>
      </label>
      <span class="cards-count" id="cards-count">
        {totalCategories} categories
      </span>
    </div>
  </header>

  <div
    class="cards-scroll"
    id="cards-scroll"
    data-lenis-prevent
    role="region"
    aria-label="Asset category list"
  >
    <div class="cards-list" id="cards-list">
      {TAG_CARDS.map((t, i) => (
        <TagCard
          tag={t.tag}
          title={t.title}
          cat={t.cat}
          format={t.format}
          desc={t.desc}
          thumbId={t.thumbId}
          thumbLabel={t.thumbLabel}
          count={FA_DATA[t.tag].length}
          game={t.game}
          active={t.tag === activeTag}
          eager={i === 0}
        />
      ))}
    </div>
  </div>

  <footer class="site-footer" role="contentinfo" aria-label="Sidebar footer">
    <div class="site-footer__row site-footer__row--actions">
      <p class="site-footer__stats">FREE · 25 ASSETS · CC0</p>
    </div>
    <div class="site-footer__divider" aria-hidden="true"></div>
    <div class="site-footer__row site-footer__row--pill">
      <a
        href="https://t.me/WhiteCatWeb"
        class="top-pill top-pill--contact site-footer__contact"
        id="contact-pill"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contact via Telegram"
        title="Contact · Telegram"
        data-cursor="link"
      >
        <svg
          class="top-pill__icon"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M2.5 10.5l15-7-2.7 14-5-4.3-2.7 3V12l7-6.3" />
        </svg>
        <span class="top-pill__label">Contact</span>
      </a>
      <a
        href="/"
        class="top-pill top-pill--free site-footer__free"
        id="portfolio-footer"
        title="Back to portfolio"
        data-cursor="link"
      >
        <span class="top-pill__label">Portfolio</span>
      </a>
    </div>
  </footer>
</aside>
