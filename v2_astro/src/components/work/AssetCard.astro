---
/**
 * AssetCard — single .fa-card in the free-assets grid. Markup mirrors
 * the legacy renderGrid() output (free-assets.js:53-100):
 *   • SVG poster (<img>) acts as decorative fallback. data-label
 *     pseudo overlay shows the bg gradient when the file is missing
 *     (delegated error-handler with `onerror="this.remove()"`).
 *   • <model-viewer> auto-rotate preview overlays the poster on top —
 *     hidden until the customElement is registered by free-assets.ts'
 *     ensureModelViewer() (lazy on first fa-card intersection so we
 *     don't dominate the LCP budget). loadfailure adds
 *     .fa-card__thumb-mv--failed → CSS hides the MV, SVG stays visible.
 *   • Download button is a plain <a download> — JS-free file delivery.
 *
 * data-asset-tag carries the canonical category key (matches the
 * sidebar TagCard's data-tag) so src/scripts/free-assets.ts can filter
 * cards with a single attribute lookup.
 */
import type { FaAsset, FaCategoryKey } from '@data/free-assets';

export interface Props {
  asset: FaAsset;
  /** Canonical category key the asset belongs to. */
  tag: FaCategoryKey;
  /** First visible card gets eager + fetchpriority for LCP. */
  eager?: boolean;
  /** SSR-pre-hidden flag — emitted as the [hidden] attribute. */
  hidden?: boolean;
}

const { asset: a, tag, eager = false, hidden = false } = Astro.props;
---

<li
  class="fa-card"
  data-asset-id={a.id}
  data-asset-tag={tag}
  data-game-asset={a.badge === 'Game Asset' ? 'true' : 'false'}
  hidden={hidden}
>
  <div class="fa-card__thumb" data-label={a.title} style={`background: ${a.bg};`}>
    <img
      src={`/works/${a.id}/thumb.svg`}
      alt=""
      aria-hidden="true"
      width="800"
      height="600"
      loading={eager ? 'eager' : 'lazy'}
      fetchpriority={eager ? 'high' : undefined}
      decoding="async"
      onerror="this.remove();"
    />
    <model-viewer
      class="fa-card__thumb-mv"
      src={`/models/free/${a.id}.glb`}
      alt={`${a.title} — interactive 3D preview`}
      auto-rotate
      rotation-per-second="20deg"
      interaction-prompt="none"
      disable-zoom
      disable-pan
      shadow-intensity="0.4"
      exposure="1.0"
      tone-mapping="aces"
      loading="lazy"
      reveal="auto"
    ></model-viewer>
    <span class="fa-card__badge">{a.badge}</span>
  </div>

  <div class="fa-card__body">
    <div class="fa-card__meta">
      <span class="fa-card__cat">{a.cat}</span>
      <span class="fa-card__license">CC0 — Free</span>
    </div>
    <h2 class="fa-card__title">{a.title}</h2>
    <p class="fa-card__desc">{a.desc}</p>

    <div class="fa-card__contents">
      <p class="fa-card__contents-label">Archive includes</p>
      <ul class="fa-card__contents-list">
        {a.contents.map((c) => (
          <li class="fa-card__contents-item">{c}</li>
        ))}
      </ul>
    </div>

    <a
      class="fa-card__download"
      href={`/downloads/${a.file}`}
      download={a.file}
      data-cursor="link"
      aria-label={`Download ${a.title}`}
    >
      <svg
        class="fa-card__dl-icon"
        viewBox="0 0 14 14"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M7 1v8M4 6l3 3 3-3M2 11h10"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      Download — {a.size}
    </a>
  </div>
</li>
