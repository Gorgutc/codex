---
/**
 * CaseBlueprints (Stage 7a) — renders a single SVG page of the
 * technical drawing for the current work.  Multi-page navigation +
 * Export-SVG button + fullscreen land in Stages 7b/7c.
 *
 * The grid background lives on .case-blueprints__page-canvas via the
 * CSS tokens (--bp-grid-minor / --bp-grid-major), so the SVG itself
 * carries only the parts / dimensions / callouts / view-tag in the
 * runtime path.  Title block is an HTML overlay so it stays inside the
 * canvas bounds even on letterboxed widescreen displays.
 */
import type { WorkEntry } from '@lib/works';
import { buildBlueprintSVG, getBlueprintPages } from '@lib/blueprint';

export interface Props {
  work: WorkEntry;
}

const { work } = Astro.props;
const d = work.data;

const pages = getBlueprintPages(d.slug);
const meta = pages[0]; // Stage 7a — first page only.
const pageCount = pages.length;
const svg = meta
  ? buildBlueprintSVG(d.slug, 0, { title: d.title, year: d.year })
  : null;
const scale = meta ? `1:${meta.unit === 'cm' ? '4' : '8'}` : '';
---

<div
  class="case-blueprints"
  id="case-blueprints"
  role="region"
  aria-label="Project blueprint"
  hidden
>
  <div class="case-blueprints__canvas" id="case-blueprints-canvas">
    {meta && svg ? (
      <div
        class="case-blueprints__page is-current"
        data-bp-page="0"
        data-bp-pages={pageCount}
      >
        <div class="case-blueprints__page-canvas" set:html={svg} />
        <div class="case-blueprints__title-block" aria-hidden="true">
          <div class="case-blueprints__title-block-top">
            <span class="case-blueprints__title-block-key">Project</span>
            <span class="case-blueprints__title-block-project">{d.title}</span>
          </div>
          <div class="case-blueprints__title-block-bottom">
            <div class="case-blueprints__title-block-cell">
              <span class="case-blueprints__title-block-key">Drawing No</span>
              <span class="case-blueprints__title-block-val">{meta.no}</span>
            </div>
            <div class="case-blueprints__title-block-cell">
              <span class="case-blueprints__title-block-key">Scale</span>
              <span class="case-blueprints__title-block-val">{scale}</span>
            </div>
            <div class="case-blueprints__title-block-cell">
              <span class="case-blueprints__title-block-key">Date</span>
              <span class="case-blueprints__title-block-val">{d.year ?? '—'}</span>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class="case-blueprints__placeholder mono" aria-hidden="true">
        <span>Blueprint data pending</span>
      </div>
    )}
  </div>
</div>

<style is:global>
  /* Inline fallback for the rare slug with no blueprint metadata. */
  .case-blueprints__placeholder {
    flex: 1;
    display: grid;
    place-content: center;
    gap: var(--space-2);
    text-align: center;
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }
</style>
