---
/**
 * CaseBlueprints (Stages 7a + 7b) — technical-drawing tab for the
 * current work.  Renders every page from BLUEPRINT_META (1..N) inside
 * the canvas; only the first carries `.is-current` on mount.  Stage 7b
 * adds the pager overlay (prev/next + N/total counter) and the runtime
 * wiring lives in src/scripts/case-blueprints.ts.
 *
 * Export-SVG button + fullscreen view land in Stage 7c.
 */
import type { WorkEntry } from '@lib/works';
import { buildBlueprintSVG, getBlueprintPages } from '@lib/blueprint';

export interface Props {
  work: WorkEntry;
}

const { work } = Astro.props;
const d = work.data;

const pages = getBlueprintPages(d.slug);
const pageCount = pages.length;
const scaleFor = (unit: 'mm' | 'cm') => `1:${unit === 'cm' ? '4' : '8'}`;
---

<div
  class="case-blueprints"
  id="case-blueprints"
  role="region"
  aria-label="Project blueprint"
  hidden
>
  <div
    class="case-blueprints__canvas"
    id="case-blueprints-canvas"
    data-bp-total={pageCount}
  >
    {pageCount > 0 ? (
      <Fragment>
        {pages.map((meta, idx) => {
          const svg = buildBlueprintSVG(d.slug, idx, {
            title: d.title,
            year: d.year,
          });
          return (
            <div
              class={`case-blueprints__page${idx === 0 ? ' is-current' : ''}`}
              data-bp-page={idx}
              data-bp-pages={pageCount}
              aria-hidden={idx === 0 ? 'false' : 'true'}
            >
              <div class="case-blueprints__page-canvas" set:html={svg ?? ''} />
              <div class="case-blueprints__title-block" aria-hidden="true">
                <div class="case-blueprints__title-block-top">
                  <span class="case-blueprints__title-block-key">Project</span>
                  <span class="case-blueprints__title-block-project">{d.title}</span>
                </div>
                <div class="case-blueprints__title-block-bottom">
                  <div class="case-blueprints__title-block-cell">
                    <span class="case-blueprints__title-block-key">Drawing No</span>
                    <span class="case-blueprints__title-block-val">{meta.no}</span>
                  </div>
                  <div class="case-blueprints__title-block-cell">
                    <span class="case-blueprints__title-block-key">Scale</span>
                    <span class="case-blueprints__title-block-val">{scaleFor(meta.unit)}</span>
                  </div>
                  <div class="case-blueprints__title-block-cell">
                    <span class="case-blueprints__title-block-key">Date</span>
                    <span class="case-blueprints__title-block-val">{d.year ?? '—'}</span>
                  </div>
                </div>
              </div>
            </div>
          );
        })}

        <div
          class="case-blueprints__pager"
          id="case-blueprints-pager"
          hidden={pageCount <= 1}
          role="group"
          aria-label="Blueprint pages"
        >
          <button
            type="button"
            class="case-blueprints__pager-btn case-blueprints__pager-btn--prev"
            id="case-blueprints-pager-prev"
            aria-label="Previous blueprint"
            aria-controls="case-blueprints-canvas"
            data-cursor="link"
          >
            <svg viewBox="0 0 18 18" aria-hidden="true">
              <path d="M11 4L5 9l6 5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <button
            type="button"
            class="case-blueprints__pager-btn case-blueprints__pager-btn--next"
            id="case-blueprints-pager-next"
            aria-label="Next blueprint"
            aria-controls="case-blueprints-canvas"
            data-cursor="link"
          >
            <svg viewBox="0 0 18 18" aria-hidden="true">
              <path d="M7 4l6 5-6 5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <span
            class="case-blueprints__pager-counter"
            id="case-blueprints-pager-counter"
            aria-live="polite"
          >1 / {pageCount}</span>
        </div>
      </Fragment>
    ) : (
      <div class="case-blueprints__placeholder mono" aria-hidden="true">
        <span>Blueprint data pending</span>
      </div>
    )}
  </div>
</div>

<style is:global>
  .case-blueprints__placeholder {
    flex: 1;
    display: grid;
    place-content: center;
    gap: var(--space-2);
    text-align: center;
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }
</style>
