---
/**
 * Cursor — custom ring + dot + extended states (link / work / drag),
 * pointer:fine only.
 *
 * Guards (all must pass before activation):
 *   • matchMedia('(pointer: fine)').matches
 *   • matchMedia('(hover: hover)').matches  — coarse hover hybrids opt out
 *   • !matchMedia('(prefers-reduced-motion: reduce)').matches
 *
 * State delegation (legacy main.js:3829-3892):
 *   • data-cursor="link"  — buttons, anchors, navigation arrows
 *   • data-cursor="work"  — work-card / fa-card hover (shows "VIEW →" label)
 *   • data-cursor="drag"  — 3D canvas, image gallery (crosshair)
 * mouseover bubbles → document listener reads closest('[data-cursor]')
 * and toggles `.is-link` / `.is-work` / `.is-drag` on `.cursor`.
 *
 * Stage 2 ring + dot; extended states + delegation added during Stage 11
 * bug-fix pass to bring the cursor back to legacy parity.
 */
---

<div class="cursor" aria-hidden="true" transition:persist="cursor">
  <div class="cursor-dot"></div>
  <div class="cursor__shell" aria-hidden="true">
    <span class="cursor__shell-label"></span>
    <span class="cursor__crosshair">
      <i></i><i></i><i></i><i></i>
    </span>
  </div>
</div>

<style is:global>
  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 40px;
    height: 40px;
    margin: -20px 0 0 -20px;
    border: 1px solid var(--color-primary);
    border-radius: 50%;
    pointer-events: none;
    z-index: 10001;
    transform: translate3d(-100px, -100px, 0);
    opacity: 0;
    transition: opacity 180ms var(--ease-out);
    will-change: transform;
  }
  .cursor.is-active { opacity: 1; }
  .cursor.is-hover { border-color: var(--color-text); }

  .cursor-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 6px;
    height: 6px;
    margin: -3px 0 0 -3px;
    background: var(--color-text);
    border-radius: 50%;
    transition: transform 200ms var(--ease-out);
  }
  .cursor.is-hover .cursor-dot { transform: scale(1.6); }

  /* No precise pointer → keep native cursors, hide custom. */
  @media (hover: none), (any-pointer: coarse) {
    .cursor,
    .cursor-dot { display: none; }
  }

  /* Hide native cursor only after JS-side guards pass. */
  html.cursor-fine,
  html.cursor-fine * { cursor: none; }

  @media (prefers-reduced-motion: reduce) {
    .cursor,
    .cursor-dot { display: none; }
  }
</style>

<script>
  type CursorState = {
    el: HTMLElement;
    rafId: number | null;
    tx: number;
    ty: number;
    cx: number;
    cy: number;
  };

  let state: CursorState | null = null;
  const STATE_CLASSES = ['is-link', 'is-work', 'is-drag'] as const;
  let currentDataState: string | null = null;

  // Static interactive elements that should trigger extended cursor states.
  // Mirrors legacy markStatic() in main.js:3858-3869.
  const LINK_SELECTOR =
    '.contact-btn, #contact-pill, .case-share, .case-nav__btn, ' +
    '.bp-export-btn, .case-blueprints__fs-btn, .case-blueprints__pager-btn, ' +
    '.top-pill--free, .top-pill--contact, #free-assets-footer, ' +
    '#case-back, #portfolio-footer, .case-3d__ctrl, .theme-toggle, ' +
    '.cards-toggle, .tags-dropdown__trigger, .tag-card, .case-tab, ' +
    '.fa-card__download, .game-switch, .logo, .case-mobile-bar__logo';

  function markStatic() {
    // Work-cards default to 'work' (VIEW → label on hover).
    document.querySelectorAll<HTMLElement>('.work-card:not(.tag-card)').forEach((e) => {
      if (!e.hasAttribute('data-cursor')) e.setAttribute('data-cursor', 'work');
    });
    document.querySelectorAll<HTMLElement>(LINK_SELECTOR).forEach((e) => {
      if (!e.hasAttribute('data-cursor')) e.setAttribute('data-cursor', 'link');
    });
    // 3D canvas → drag state (rotate cursor hint).
    document.querySelectorAll<HTMLElement>('#case-3d-canvas, .case-item__media').forEach((e) => {
      if (!e.hasAttribute('data-cursor')) e.setAttribute('data-cursor', 'drag');
    });
  }

  function applyCursorState(stateName: string | null) {
    const cursorEl = document.querySelector<HTMLElement>('.cursor');
    if (!cursorEl) return;
    for (const c of STATE_CLASSES) cursorEl.classList.remove(c);
    if (stateName === 'link' || stateName === 'work' || stateName === 'drag') {
      cursorEl.classList.add(`is-${stateName}`);
    }
  }

  function onMouseOver(e: MouseEvent) {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const el = target.closest<HTMLElement>('[data-cursor]');
    const next = el ? el.getAttribute('data-cursor') : null;
    if (next === currentDataState) return;
    currentDataState = next;
    applyCursorState(next);
  }

  function init() {
    const cursorEl = document.querySelector<HTMLElement>('.cursor');
    if (!cursorEl) return;

    const fine = window.matchMedia('(pointer: fine)').matches;
    const hover = window.matchMedia('(hover: hover)').matches;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!fine || !hover || reduced) return;

    document.documentElement.classList.add('cursor-fine');

    state = {
      el: cursorEl,
      rafId: null,
      tx: -100,
      ty: -100,
      cx: -100,
      cy: -100,
    };

    const onMove = (e: MouseEvent) => {
      if (!state) return;
      state.tx = e.clientX;
      state.ty = e.clientY;
      if (!cursorEl.classList.contains('is-active')) cursorEl.classList.add('is-active');
      if (state.rafId == null) state.rafId = requestAnimationFrame(tick);
    };

    const onLeave = () => cursorEl.classList.remove('is-active');

    function tick() {
      if (!state) return;
      state.cx += (state.tx - state.cx) * 0.35;
      state.cy += (state.ty - state.cy) * 0.35;
      state.el.style.transform = `translate3d(${state.cx}px, ${state.cy}px, 0)`;

      const dx = state.tx - state.cx;
      const dy = state.ty - state.cy;
      if (Math.abs(dx) < 0.1 && Math.abs(dy) < 0.1) {
        state.rafId = null;
        return;
      }
      state.rafId = requestAnimationFrame(tick);
    }

    window.addEventListener('mousemove', onMove, { passive: true });
    window.addEventListener('mouseleave', onLeave);

    // Tag interactive elements + delegated state switch.
    markStatic();
    document.addEventListener('mouseover', onMouseOver);
  }

  function destroy() {
    if (state?.rafId != null) cancelAnimationFrame(state.rafId);
    state = null;
    document.removeEventListener('mouseover', onMouseOver);
    currentDataState = null;
  }

  init();
  document.addEventListener('astro:before-swap', destroy);
  document.addEventListener('astro:page-load', init);
</script>
