---
/**
 * ThemeToggle — light/dark cookie-persisted switch.
 *
 * Strategy:
 *   • SSR renders the dark-default aria state; the cookie-init script in
 *     BaseLayout has already flipped <body data-theme="light"> before
 *     paint when codex-theme=light, so the icon swap is visually correct.
 *   • Click handler flips <body data-theme>, updates the single
 *     <meta name="theme-color"> content (frozen META-theme-color-single),
 *     writes `codex-theme` cookie (Max-Age=1y, SameSite=Lax).
 *   • NO localStorage — sandbox-fragile, disallowed by build_rules.md.
 *   • View Transitions safe: the click handler is re-bound by the
 *     `astro:page-load` event so it survives ClientRouter swaps.
 */
---

<button
  type="button"
  class="theme-toggle"
  id="theme-toggle"
  aria-pressed="false"
  aria-label="Switch to light theme"
  data-cursor="link"
>
  <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="12" cy="12" r="4" />
      <path
        d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
        stroke-linecap="round"
      />
    </svg>
  </span>
  <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
    </svg>
  </span>
</button>

<style>
  .theme-toggle {
    position: relative;
    width: 36px;
    height: 36px;
    display: inline-grid;
    place-items: center;
    color: var(--color-text);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-sm);
    background: transparent;
    transition: border-color 0.18s var(--ease-out), color 0.18s var(--ease-out);
  }
  .theme-toggle:hover {
    border-color: var(--color-border);
    color: var(--color-primary);
  }
  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .theme-toggle__icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1) rotate(0deg);
    transition:
      opacity 0.22s var(--ease-out),
      transform 0.32s var(--ease-out);
    display: grid;
    place-items: center;
  }

  /* Dark theme — moon visible, sun hidden, scaled down. */
  [data-theme='dark'] .theme-toggle__icon--sun {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.6) rotate(-90deg);
  }
  [data-theme='dark'] .theme-toggle__icon--moon {
    opacity: 1;
  }

  /* Light theme — sun visible, moon hidden. */
  [data-theme='light'] .theme-toggle__icon--sun {
    opacity: 1;
  }
  [data-theme='light'] .theme-toggle__icon--moon {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.6) rotate(90deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle__icon {
      transition: opacity 0ms;
      transform: translate(-50%, -50%) scale(1) rotate(0deg) !important;
    }
  }
</style>

<script>
  const COOKIE_NAME = 'codex-theme';
  const COOKIE_MAX_AGE = 60 * 60 * 24 * 365; // 1y

  function writeThemeCookie(theme: 'dark' | 'light') {
    document.cookie = `${COOKIE_NAME}=${theme}; path=/; max-age=${COOKIE_MAX_AGE}; samesite=lax`;
  }

  function applyTheme(next: 'dark' | 'light') {
    const isLight = next === 'light';
    document.body.setAttribute('data-theme', next);

    const themeMeta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
    if (themeMeta) {
      themeMeta.setAttribute('content', isLight ? '#f5f5f5' : '#212121');
    }

    const btn = document.getElementById('theme-toggle');
    if (btn) {
      btn.setAttribute('aria-pressed', isLight ? 'true' : 'false');
      btn.setAttribute(
        'aria-label',
        isLight ? 'Switch to dark theme' : 'Switch to light theme',
      );
    }

    writeThemeCookie(next);
  }

  function syncAria() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const isLight = document.body.getAttribute('data-theme') === 'light';
    btn.setAttribute('aria-pressed', isLight ? 'true' : 'false');
    btn.setAttribute(
      'aria-label',
      isLight ? 'Switch to dark theme' : 'Switch to light theme',
    );
  }

  function bindToggle() {
    syncAria();
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';
    btn.addEventListener('click', () => {
      const current = document.body.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });
  }

  // Initial bind + rebind after each View Transition swap.
  bindToggle();
  document.addEventListener('astro:page-load', bindToggle);
</script>
