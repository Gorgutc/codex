---
/**
 * ThemeToggle — light/dark cookie-persisted switch.
 *
 * Markup mirrors codex/index.html line 242-259 verbatim so the global
 * `.theme-toggle` rules in components/sidebar.css apply without
 * duplication.  The cookie-init script in BaseLayout has already
 * flipped <body data-theme="light"> before paint when codex-theme=light,
 * so the SVG icon swap is correct on first render.
 *
 * Click behaviour:
 *   • Flip <body data-theme>
 *   • Update the single <meta name="theme-color"> content (frozen
 *     META-theme-color-single from verify-frozen.js v0.8)
 *   • Write `codex-theme` cookie (Max-Age=1y, SameSite=Lax)
 *   • Rebind after astro:page-load so View Transitions survive
 */
---

<button
  type="button"
  class="theme-toggle"
  id="theme-toggle"
  aria-pressed="false"
  aria-label="Switch to light theme"
  title="Toggle theme"
  data-cursor="link"
>
  <svg
    class="theme-toggle__icon theme-toggle__icon--sun"
    viewBox="0 0 20 20"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    aria-hidden="true"
  >
    <circle cx="10" cy="10" r="3.4"></circle>
    <path
      d="M10 2v2M10 16v2M4.2 4.2l1.4 1.4M14.4 14.4l1.4 1.4M2 10h2M16 10h2M4.2 15.8l1.4-1.4M14.4 5.6l1.4-1.4"
    ></path>
  </svg>
  <svg
    class="theme-toggle__icon theme-toggle__icon--moon"
    viewBox="0 0 20 20"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path
      d="M16.5 11.8A6.8 6.8 0 0 1 8.2 3.5a.5.5 0 0 0-.7-.6 7.5 7.5 0 1 0 9.6 9.6.5.5 0 0 0-.6-.7Z"
    ></path>
  </svg>
</button>

<script>
  const COOKIE_NAME = 'codex-theme';
  const COOKIE_MAX_AGE = 60 * 60 * 24 * 365; // 1y

  function writeThemeCookie(theme: 'dark' | 'light') {
    document.cookie = `${COOKIE_NAME}=${theme}; path=/; max-age=${COOKIE_MAX_AGE}; samesite=lax`;
  }

  function applyTheme(next: 'dark' | 'light') {
    const isLight = next === 'light';
    document.body.setAttribute('data-theme', next);

    const themeMeta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
    if (themeMeta) themeMeta.setAttribute('content', isLight ? '#f5f5f5' : '#212121');

    syncAria();
    writeThemeCookie(next);
  }

  function syncAria() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const isLight = document.body.getAttribute('data-theme') === 'light';
    btn.setAttribute('aria-pressed', isLight ? 'true' : 'false');
    btn.setAttribute('aria-label', isLight ? 'Switch to dark theme' : 'Switch to light theme');
  }

  function bindToggle() {
    syncAria();
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';
    btn.addEventListener('click', () => {
      const current = document.body.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });
  }

  bindToggle();
  document.addEventListener('astro:page-load', bindToggle);
</script>
