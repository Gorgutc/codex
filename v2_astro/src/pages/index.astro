---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/layout/Sidebar.astro';
import CaseScroll from '@components/work/CaseScroll.astro';
import { getFeaturedWorks } from '@lib/works';

const title = 'Codex — 3D Design Studio · Hard Surface & Product Visualization';
const description =
  'Codex is a remote 3D design studio specializing in hard surface modeling, product visualization, and game-ready assets. Built in Blender. Available worldwide.';

// Stage 5a — render the first featured work as the default case. Hash-routing
// + click-to-open + work-card--active sync land in Stage 5c.
const [defaultWork] = await getFeaturedWorks(1);
---

<BaseLayout title={title} description={description}>
  <div class="layout">
    <Sidebar />

    <main class="main-area" id="main">
      <section
        class="case-view"
        id="case-view"
        aria-label="Project case study"
      >
        {defaultWork && <CaseScroll work={defaultWork} />}
      </section>
    </main>
  </div>
</BaseLayout>

<script>
  import '~/scripts/sidebar';
</script>
