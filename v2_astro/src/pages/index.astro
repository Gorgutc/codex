---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/layout/Sidebar.astro';
import CaseView from '@components/work/CaseView.astro';
import { getAllWorks } from '@lib/works';

const title = 'Codex — 3D Design Studio · Hard Surface & Product Visualization';
const description =
  'Codex is a remote 3D design studio specializing in hard surface modeling, product visualization, and game-ready assets. Built in Blender. Available worldwide.';

// Stage 5b — render the first sidebar work as the default case. Hash routing,
// click-to-open and live counter updates land in Stage 5c.
const works = await getAllWorks();
const defaultWork = works[0]!;
---

<BaseLayout title={title} description={description}>
  <div class="layout">
    <Sidebar />

    <main class="main-area" id="main">
      <CaseView work={defaultWork} index={1} total={works.length} />
    </main>
  </div>
</BaseLayout>

<script>
  import '~/scripts/sidebar';
</script>
