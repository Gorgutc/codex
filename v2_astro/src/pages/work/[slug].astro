---
/**
 * /work/[slug]/ — case study page (one per work in the collection).
 *
 * MPA model with View Transitions: each click on a sidebar .work-card
 * triggers a ClientRouter swap to /work/<slug>/. The Sidebar uses
 * transition:persist so filter state and scroll position survive
 * navigations; the main-area swaps to the new case-view.
 *
 * Build emits 18 pages (one per work in src/content/works/) via the
 * required getStaticPaths() — Astro 5 static collections.
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/layout/Sidebar.astro';
import CaseView from '@components/work/CaseView.astro';
import { getAllWorks, getFeaturedWorks } from '@lib/works';
import type { JsonLd } from '@layouts/BaseLayout.astro';
import {
  getOrganizationSchema,
  getWebSiteSchema,
  getFeaturedItemListSchema,
} from '@lib/schemas';

export const getStaticPaths = (async () => {
  const works = await getAllWorks();
  return works.map((work, i) => ({
    params: { slug: work.data.slug },
    props: { work, index: i + 1, total: works.length },
  }));
}) satisfies GetStaticPaths;

const { work, index, total } = Astro.props;
const d = work.data;

// Discipline-first label for the page <title>; 'Game Asset' is a dimension,
// not a category, so prefer Hard Surface / Product Viz / etc.
const primaryCat = d.category.filter((c) => c !== 'Game Asset')[0] ?? d.category[0]!;
const title = `${d.title} — ${primaryCat} · Codex Studio`;
const description = d.description;
// Per-page og:image lands in Stage 10. Default to the shared studio image.
const ogImage = '/img/og-image.jpg';

// CreativeWork JSON-LD for the case page.
const creativeWork: JsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: d.title,
  description: d.description,
  url: new URL(`/work/${d.slug}/`, Astro.site ?? 'https://preview.codex.promo/').toString(),
  creator: { '@type': 'Organization', name: 'Codex Studio' },
  about: d.category.join(' · '),
  dateCreated: String(d.year),
  ...(d.specs?.tools && { producer: d.specs.tools.join(' / ') }),
};

// Sitewide schemas + featured ItemList on the redirect target (the work
// that `/` redirects to is the canonical home for crawler indexing).
const schemas: JsonLd[] = [
  getOrganizationSchema(),
  getWebSiteSchema(),
  creativeWork,
];
const isRedirectTarget = d.slug === 'orbital-mk-ii';
if (isRedirectTarget) {
  const featured = await getFeaturedWorks(4);
  schemas.push(
    getFeaturedItemListSchema(
      featured.map((w) => ({
        slug: w.data.slug,
        title: w.data.title,
        about: w.data.category.filter((c) => c !== 'Game Asset').join(' · '),
      })),
    ),
  );
}
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogImageAlt={`${d.title} — Codex Studio case study`}
  ogType="article"
  schemas={schemas}
>
  <div class="layout">
    <Sidebar />

    <main class="main-area" id="main">
      <CaseView work={work} index={index} total={total} />
    </main>
  </div>
</BaseLayout>

<script>
  import '~/scripts/sidebar';
  import '~/scripts/case-view';
  import '~/scripts/case-3d';
  import '~/scripts/case-blueprints';
  import '~/scripts/animations';
</script>
