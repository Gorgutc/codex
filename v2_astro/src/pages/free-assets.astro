---
/**
 * /free-assets/ — catalogue page (Stage 9a + 9b).
 *
 * Renders every FA_DATA asset in a single fa-grid; the FreeAssetsSidebar
 * to the left exposes six tag-cards (one per category).  src/scripts/
 * free-assets.ts toggles `[hidden]` on the asset cards in response to
 * tag-card clicks + location.hash changes — pre-rendered cards outside
 * the initial category ship with `hidden` set so the first paint
 * already matches activeTag without any client-side handshake.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import FreeAssetsSidebar from '@components/layout/FreeAssetsSidebar.astro';
import AssetCard from '@components/work/AssetCard.astro';
import {
  FA_CATEGORY_ORDER,
  FA_DATA,
  FA_CATEGORY_LABELS,
} from '@data/free-assets';

const activeTag = 'hard-surface' as const;
const initialLabel = FA_CATEGORY_LABELS[activeTag];

// Flatten with category tag info — preserves order and category.
const entries = FA_CATEGORY_ORDER.flatMap((tag) =>
  FA_DATA[tag].map((asset) => ({ asset, tag })),
);
const initialVisible = entries.filter((e) => e.tag === activeTag);

const title = 'Free 3D Assets — Codex Studio · Hard Surface, Game-Ready, CC0';
const description =
  'Free 3D assets by Codex Studio. Hard surface models, game-ready props, and product renders. Free for personal and commercial use under CC0 / CC-BY.';

const ogImage = '/img/og-free-assets.jpg';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Free 3D Assets — Codex Studio',
  description,
  url: new URL('/free-assets/', Astro.site ?? 'https://preview.codex.promo/').toString(),
  primaryImageOfPage: ogImage,
  publisher: { '@type': 'Organization', name: 'Codex Studio' },
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogImageAlt="Codex Studio — Free 3D Assets"
  ogType="website"
  schemas={[schema]}
>
  <div class="layout">
    <FreeAssetsSidebar activeTag={activeTag} />

    <main class="main-area" id="main">
      <section class="fa-view" id="fa-view" aria-label="Free assets">
        <div class="fa-view__header">
          <div>
            <div class="fa-view__meta">
              <span class="fa-view__cat" id="fa-view-cat">{initialLabel}</span>
              <span class="fa-view__sep" aria-hidden="true">·</span>
              <span class="fa-view__count" id="fa-view-count">
                {initialVisible.length} asset{initialVisible.length === 1 ? '' : 's'}
              </span>
            </div>
            <h1 class="fa-view__title" id="fa-view-title">{initialLabel}</h1>
          </div>
        </div>

        <div class="fa-scroll" id="fa-scroll">
          <ul class="fa-grid" id="fa-grid">
            {entries.map(({ asset, tag }, i) => (
              <AssetCard
                asset={asset}
                tag={tag}
                hidden={tag !== activeTag}
                eager={tag === activeTag && i < FA_DATA[activeTag].length && asset.id === FA_DATA[activeTag][0]?.id}
              />
            ))}
          </ul>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<script>
  import '~/scripts/sidebar';
  import '~/scripts/free-assets';
</script>
