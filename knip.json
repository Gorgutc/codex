{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "admin/js/api.js",
    "admin/js/state.js",
    "admin/js/ui.js",
    "js/animations.js",
    "js/cards-data.js",
    "js/fa-data.js",
    "js/free-assets.js",
    "js/i18n-data.js",
