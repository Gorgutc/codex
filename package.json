{
  "name": "codex",
  "version": "1.0.0",
  "description": "Codex Studio — портфолио-сайт 3D-дизайн-студии. Vanilla HTML+CSS+JS, deploy на статический хост.",
  "private": true,
  "scripts": {
    "verify": "node verify-frozen.js",
    "codex:verify-plugin": "node scripts/verify-codex-plugin.mjs",
    "sync:harness": "node scripts/sync-harness.mjs --write",
    "check:parity": "node scripts/sync-harness.mjs --check",
    "content:generate": "node scripts/generate-content.mjs --write",
    "content:check": "node scripts/generate-content.mjs --check",
    "test:golden": "playwright test tests/quality/content-golden.spec.mjs",
    "test:content-validate": "node tests/quality/content-validate.test.mjs && node tests/quality/content-visibility.test.mjs",
    "test:verify-fatal": "node tests/quality/verify-frozen-fatal-exit.test.mjs",
    "codex:ship": "npm run codex:verify-plugin && npm run check:governance && npm run check:parity && npm run content:check && npm run test:golden && npm run test:verify-fatal && npm run verify",
    "check:js": "eslint \"js/**/*.js\" \"admin/js/**/*.js\" \"netlify/functions/**/*.mjs\" \"scripts/**/*.mjs\" \"verify-frozen.js\" \"*.config.mjs\" \"*.config.cjs\"",
    "check:css": "stylelint \"css/**/*.css\"",
    "check:html": "htmlhint \"*.html\" \"admin/*.html\"",
    "check:markdown": "markdownlint-cli2 \"*.md\" \"docs/**/*.md\" \".agents/**/*.md\" \"plugins/**/*.md\"",
    "check:spelling": "cspell",
    "check:deps": "depcruise --config dependency-cruiser.config.cjs \"js/**/*.js\" \"admin/js/**/*.js\" \"netlify/functions/**/*.mjs\" \"scripts/**/*.mjs\" \"verify-frozen.js\"",
    "check:dead": "knip",
    "check:duplicates": "jscpd",
    "check:governance": "node scripts/check-governance.mjs",
    "check:audit": "npm audit --omit=dev --audit-level=high",
    "check:a11y": "node scripts/run-pa11y.mjs",
    "check:lighthouse": "node scripts/run-lhci.mjs",
    "test:admin": "playwright test tests/quality/admin-smoke.spec.mjs tests/quality/admin-media.spec.mjs tests/quality/admin-order-visibility.spec.mjs",
    "test:browser": "playwright test tests/quality/site-smoke.spec.mjs",
    "test:visual": "playwright test tests/quality/visual-regression.spec.mjs",
    "test:visual:update": "playwright test tests/quality/visual-regression.spec.mjs --update-snapshots",
    "quality:governance": "npm run check:governance",
    "format": "prettier --write \"*.{json,yml,yaml,cjs,mjs}\" \"scripts/**/*.mjs\" \"tests/**/*.mjs\" \"docs/agent/quality-tooling.md\"",
    "format:all": "prettier --write .",
    "check:format": "prettier --check \"*.{json,yml,yaml,cjs,mjs}\" \"scripts/**/*.mjs\" \"tests/**/*.mjs\" \"docs/agent/quality-tooling.md\"",
    "quality:fast": "npm run codex:verify-plugin && npm run check:governance && npm run content:check && npm run check:js && npm run check:css && npm run check:html && npm run check:markdown && npm run check:spelling && npm run check:deps && npm run check:audit",
    "quality:deep": "npm run quality:fast && npm run check:dead && npm run check:duplicates && npm run test:content-validate && npm run test:browser && npm run test:admin && npm run check:a11y",
    "quality:all": "npm run quality:deep && npm run quality:governance && npm run test:visual && npm run check:lighthouse && npm run codex:ship",
    "hooks:install": "lefthook install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Gorgutc/codex.git"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cspell/dict-ru_ru": "^2.3.2",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "cspell": "^10.0.0",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^10.4.0",
    "htmlhint": "^1.9.2",
    "jscpd": "^4.2.4",
    "knip": "^6.14.2",
    "lefthook": "^2.1.8",
    "lighthouse": "^12.6.1",
    "markdownlint-cli2": "^0.22.1",
    "pa11y": "^9.1.1",
    "playwright": "^1.56.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
