    "ADRs",
    "axe",
    "Beget",
    "cspell",
    "depcruise",
    "EPERM",
    "evals",
    "Fontshare",
    "frontend",
    "frontmatter",
    "Gorgutc",
    "GSAP",
    "htmlhint",
    "i18n",
    "jscpd",
    "Knip",
    "Lenis",
    "lhci",
    "llms",
    "modelviewer",
    "Negotiables",
    "pa11y",
    "Playwright",
    "ScrollTrigger",
    "SplitText",
    "stylelint",
    "subagents",
    "worktree"
  ]
}
