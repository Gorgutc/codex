{
  "version": "0.2",
  "language": "en,ru",
  "files": [
    "AGENTS.md",
    "README.md",
    "RUN_INSTRUCTIONS.md",
    "docs/agent/**/*.md",
    ".agents/skills/**/*.md",
    "plugins/codex-studio-codex/skills/**/*.md"
