{
  "innerHTML": "\n\n        <!-- ══════════════════════════════════════════════════════════════════════\n             КАРТОЧКИ\n             ─────────────────────────────────────────────────────────────────────\n             Как заменить плейсхолдер на реальное превью:\n\n             1. Положи JPG/WEBP в ./assets/img/work/ с именем как в src= ниже.\n                Рекомендуемый размер: 800×600 (4:3), ≤200 KB.\n             2. Готово. Если файл существует — он покажется. Если нет —\n                градиент + лейбл остаются как плейсхолдер (делегированный\n                error-handler в main.js удаляет <img>, см. v0.8.8a).\n\n             Рекомендуемые форматы:\n             - .webp (лучшее сжатие)  → orbital-mk-ii.webp\n             - .jpg  (fallback)        → orbital-mk-ii.jpg\n\n             Рекомендация по именованию: kebab-case, латиница, без пробелов.\n             См. ./assets/img/work/README.md\n        ══════════════════════════════════════════════════════════════════════ -->\n\n        <!-- 1 -->\n        <a class=\"work-card work-card--active\" data-id=\"orbital-mk-ii\" data-category=\"hard-surface\" href=\"#orbital-mk-ii\" aria-current=\"page\">\n          <div class=\"work-card__thumb\" data-label=\"Orbital Mk.II\">\n            <img src=\"./assets/cards/orbital-mk-ii.svg\" data-i18n-attr=\"alt:card.orbital-mk-ii.alt\" alt=\"Orbital Mk.II — sci-fi hard surface prop\" loading=\"eager\" fetchpriority=\"high\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Hard Surface</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.orbital-mk-ii.title\">Orbital Mk.II</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.orbital-mk-ii.desc\">Sci-fi prop engineered for AAA pipeline. Full PBR, clean topology.</p>\n          </div>\n        </a>\n\n        <!-- 2 -->\n        <a class=\"work-card\" data-id=\"vega-shell\" data-category=\"hard-surface\" href=\"#vega-shell\">\n          <div class=\"work-card__thumb\" data-label=\"Vega Shell\">\n            <img src=\"./assets/cards/vega-shell.svg\" data-i18n-attr=\"alt:card.vega-shell.alt\" alt=\"Vega Shell — modular exo-armor system\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Hard Surface</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.vega-shell.title\">Vega Shell</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.vega-shell.desc\">Modular exo-armor system. 47 individual parts, LOD-ready.</p>\n          </div>\n        </a>\n\n        <!-- 3 -->\n        <a class=\"work-card\" data-id=\"ironclad-frame\" data-category=\"hard-surface\" href=\"#ironclad-frame\">\n          <div class=\"work-card__thumb\" data-label=\"Ironclad Frame\">\n            <img src=\"./assets/cards/ironclad-frame.svg\" data-i18n-attr=\"alt:card.ironclad-frame.alt\" alt=\"Ironclad Frame — industrial chassis breakdown\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Hard Surface</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2024</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.ironclad-frame.title\">Ironclad Frame</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.ironclad-frame.desc\">Industrial chassis breakdown. Every bolt and seam modeled to spec.</p>\n          </div>\n        </a>\n\n        <!-- 4 -->\n        <a class=\"work-card\" data-id=\"corten-series\" data-category=\"product\" href=\"#corten-series\">\n          <div class=\"work-card__thumb\" data-label=\"Corten Series\">\n            <img src=\"./assets/cards/corten-series.svg\" data-i18n-attr=\"alt:card.corten-series.alt\" alt=\"Corten Series — industrial furniture product viz\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Product</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.corten-series.title\">Corten Series</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.corten-series.desc\">Product viz for an industrial furniture brand. Launch-ready renders.</p>\n          </div>\n        </a>\n\n        <!-- 5 -->\n        <a class=\"work-card\" data-id=\"lumen-one\" data-category=\"product\" href=\"#lumen-one\">\n          <div class=\"work-card__thumb\" data-label=\"Lumen One\">\n            <img src=\"./assets/cards/lumen-one.svg\" data-i18n-attr=\"alt:card.lumen-one.alt\" alt=\"Lumen One — architectural lighting unit\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Product</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2024</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.lumen-one.title\">Lumen One</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.lumen-one.desc\">Architectural lighting unit. Photorealistic turntable for pitch deck.</p>\n          </div>\n        </a>\n\n        <!-- 6 -->\n        <a class=\"work-card\" data-id=\"flux-capsule\" data-category=\"product\" href=\"#flux-capsule\">\n          <div class=\"work-card__thumb\" data-label=\"Flux Capsule\">\n            <img src=\"./assets/cards/flux-capsule.svg\" data-i18n-attr=\"alt:card.flux-capsule.alt\" alt=\"Flux Capsule — consumer tech device\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Product</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2024</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.flux-capsule.title\">Flux Capsule</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.flux-capsule.desc\">Consumer tech device. E-commerce shot set, studio lighting rig.</p>\n          </div>\n        </a>\n\n        <!-- 7 — Nightshard. Hard Surface + Game Asset badge -->\n        <a class=\"work-card\" data-id=\"nightshard\" data-category=\"hard-surface\" data-game-asset=\"true\" href=\"#nightshard\">\n          <div class=\"work-card__thumb\" data-label=\"Nightshard\">\n            <img src=\"./assets/cards/nightshard.svg\" data-i18n-attr=\"alt:card.nightshard.alt\" alt=\"Nightshard — hero weapon asset, game-ready\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n            <span class=\"work-card__badge\">Game</span>\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Hard Surface</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.nightshard.title\">Nightshard</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.nightshard.desc\">Hero weapon asset. 4K PBR textures, optimised for real-time.</p>\n          </div>\n        </a>\n\n        <!-- 8 — Recon Drone. Hard Surface + Game Asset badge -->\n        <a class=\"work-card\" data-id=\"recon-drone\" data-category=\"hard-surface\" data-game-asset=\"true\" href=\"#recon-drone\">\n          <div class=\"work-card__thumb\" data-label=\"Recon Drone\">\n            <img src=\"./assets/cards/recon-drone.svg\" data-i18n-attr=\"alt:card.recon-drone.alt\" alt=\"Recon Drone — tactical UAV prop\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n            <span class=\"work-card__badge\">Game</span>\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Hard Surface</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2024</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.recon-drone.title\">Recon Drone</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.recon-drone.desc\">Tactical UAV prop. Game-ready, LOD0–LOD2, UE5-compatible.</p>\n          </div>\n        </a>\n\n        <!-- 9 -->\n        <a class=\"work-card\" data-id=\"apex-frame\" data-category=\"prototyping\" href=\"#apex-frame\">\n          <div class=\"work-card__thumb\" data-label=\"Apex Frame\">\n            <img src=\"./assets/cards/apex-frame.svg\" data-i18n-attr=\"alt:card.apex-frame.alt\" alt=\"Apex Frame — mechanical component breakdown\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Prototyping</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2024</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.apex-frame.title\">Apex Frame</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.apex-frame.desc\">Mechanical component breakdown for engineering client. Mfg-reference accuracy.</p>\n          </div>\n        </a>\n\n        <!-- 10 -->\n        <a class=\"work-card\" data-id=\"core-rig\" data-category=\"prototyping\" href=\"#core-rig\">\n          <div class=\"work-card__thumb\" data-label=\"Core Rig\">\n            <img src=\"./assets/cards/core-rig.svg\" data-i18n-attr=\"alt:card.core-rig.alt\" alt=\"Core Rig — structural assembly prototype\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Prototyping</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2024</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.core-rig.title\">Core Rig</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.core-rig.desc\">Structural assembly prototype. Modeled for 3D-print validation.</p>\n          </div>\n        </a>\n\n        <!-- 11 -->\n        <a class=\"work-card\" data-id=\"helix-reveal\" data-category=\"animations\" href=\"#helix-reveal\">\n          <div class=\"work-card__thumb\" data-label=\"Helix Reveal\">\n            <img src=\"./assets/cards/helix-reveal.svg\" data-i18n-attr=\"alt:card.helix-reveal.alt\" alt=\"Helix Reveal — product reveal animation\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Animations</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.helix-reveal.title\">Helix Reveal</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.helix-reveal.desc\">Product reveal animation. 6-second loop, render for hero section.</p>\n          </div>\n        </a>\n\n        <!-- 12 -->\n        <a class=\"work-card\" data-id=\"arc-motion\" data-category=\"animations\" href=\"#arc-motion\">\n          <div class=\"work-card__thumb\" data-label=\"Arc Motion\">\n            <img src=\"./assets/cards/arc-motion.svg\" data-i18n-attr=\"alt:card.arc-motion.alt\" alt=\"Arc Motion — turntable sequence for industrial product\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Animations</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2024</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.arc-motion.title\">Arc Motion</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.arc-motion.desc\">Turntable sequence for industrial product. 360° orbit, 4K export.</p>\n          </div>\n        </a>\n\n        <!-- 13 — Organic -->\n        <a class=\"work-card\" data-id=\"nyx-panther\" data-category=\"organic\" href=\"#nyx-panther\">\n          <div class=\"work-card__thumb\" data-label=\"Nyx Panther\">\n            <img src=\"./assets/cards/nyx-panther.svg\" data-i18n-attr=\"alt:card.nyx-panther.alt\" alt=\"Nyx Panther — stylized feline creature\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Organic</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.nyx-panther.title\">Nyx Panther</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.nyx-panther.desc\">Stylized feline creature. Hand-sculpted anatomy, dual-coat fur groom.</p>\n          </div>\n        </a>\n\n        <!-- 14 — Organic -->\n        <a class=\"work-card\" data-id=\"drift-koi\" data-category=\"organic\" href=\"#drift-koi\">\n          <div class=\"work-card__thumb\" data-label=\"Drift Koi\">\n            <img src=\"./assets/cards/drift-koi.svg\" data-i18n-attr=\"alt:card.drift-koi.alt\" alt=\"Drift Koi — ornamental fish study\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Organic</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2024</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.drift-koi.title\">Drift Koi</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.drift-koi.desc\">Ornamental fish study. Displacement scales, subsurface scattering pass.</p>\n          </div>\n        </a>\n\n        <!-- 15 — Organic -->\n        <a class=\"work-card\" data-id=\"glint-owl\" data-category=\"organic\" href=\"#glint-owl\">\n          <div class=\"work-card__thumb\" data-label=\"Glint Owl\">\n            <img src=\"./assets/cards/glint-owl.svg\" data-i18n-attr=\"alt:card.glint-owl.alt\" alt=\"Glint Owl — stylized bird character\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">Organic</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.glint-owl.title\">Glint Owl</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.glint-owl.desc\">Stylized bird character. Feather grooming with procedural asymmetry.</p>\n          </div>\n        </a>\n\n        <!-- 16 — CAD study (v0.14.0 [15a]) — data-cad-placeholder=\"true\" для будущей замены -->\n        <a class=\"work-card\" data-id=\"mech-link\" data-category=\"cad\" data-cad-placeholder=\"true\" href=\"#mech-link\">\n          <div class=\"work-card__thumb\" data-label=\"Mech Link\">\n            <img src=\"./assets/cards/mech-link.svg\" data-i18n-attr=\"alt:card.mech-link.alt\" alt=\"Mech Link — CAD linkage assembly\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">CAD</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.mech-link.title\">Mech Link</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.mech-link.desc\">Industrial CAD linkage. Parametric pins, exploded tolerances, production handoff view.</p>\n          </div>\n        </a>\n\n        <!-- 17 — CAD study -->\n        <a class=\"work-card\" data-id=\"flex-spine\" data-category=\"cad\" data-cad-placeholder=\"true\" href=\"#flex-spine\">\n          <div class=\"work-card__thumb\" data-label=\"Flex Spine\">\n            <img src=\"./assets/cards/flex-spine.svg\" data-i18n-attr=\"alt:card.flex-spine.alt\" alt=\"Flex Spine — kinematic CAD spine study\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">CAD</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.flex-spine.title\">Flex Spine</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.flex-spine.desc\">Kinematic spine study. CAD constraints and parametric ribs for motion review.</p>\n          </div>\n        </a>\n\n        <!-- 18 — CAD study -->\n        <a class=\"work-card\" data-id=\"cad-strut\" data-category=\"cad\" data-cad-placeholder=\"true\" href=\"#cad-strut\">\n          <div class=\"work-card__thumb\" data-label=\"CAD Strut\">\n            <img src=\"./assets/cards/cad-strut.svg\" data-i18n-attr=\"alt:card.cad-strut.alt\" alt=\"CAD Strut — structural node assembly\" loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"600\">\n          </div>\n          <div class=\"work-card__info\">\n            <div class=\"work-card__meta\"><span class=\"work-card__cat\">CAD</span><span class=\"work-card__meta-tail\"><span class=\"work-card__year\">2025</span><span class=\"work-card__hint\" aria-hidden=\"true\">↗</span></span></div>\n            <h2 class=\"work-card__title\" data-i18n=\"card.cad-strut.title\">CAD Strut</h2>\n            <p class=\"work-card__desc\" data-i18n=\"card.cad-strut.desc\">Structural strut node. CAD-first geometry with bolt-pattern variants and PBR finish study.</p>\n          </div>\n        </a>\n\n      "
